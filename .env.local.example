# Postgres (Neon / Supabase / Railway)
# The DATABASE_URL is the pooled connection; DIRECT_URL is the direct connection
# (required by Prisma for migrations on Neon/Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?connect_timeout=15"

# Upstash Redis (REST API)
UPSTASH_REDIS_REST_URL="https://YOUR-ENDPOINT.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_TOKEN"

# A random secret used to authenticate the /api/cron/expire endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET="62554a22ec5cfaa54bdb761d0327c7ab77b61c59a9fb66bfa0a1673d76bab825"
